{
  "portMap": {
    "0x01": { "command": "ping",             "type": "diagnostic" },
    "0x04": { "command": "obc_reboot",       "target": "obc" },
    "0x14": { "command": "adcs_mode",        "target": "adcs", "resolve": { "0x00": "adcs_idle", "0x02": "adcs_manual" } },
    "0x15": { "command": "adcs_target",      "target": "adcs" },
    "0x18": { "command": "transponder_ctrl", "target": "transponder" }
  },

  "hardware": {
    "solar_panel": {
      "defaults": { "angle": 90, "power": 4.2 },
      "specs": { "maxPower": 4.2, "motorSpeed": 2, "optimalAngle": 90 }
    },
    "battery": {
      "defaults": { "level": 100 },
      "specs": { "capacity": 100 }
    },
    "antenna": {
      "defaults": { "az": 180, "el": 45, "deployed": true },
      "specs": { "type": "monopole", "beamwidth": 35, "motorSpeed": 3, "canStow": true }
    },
    "comm": {
      "defaults": { "status": "CONNECTED" },
      "specs": {}
    },
    "transponder": {
      "defaults": { "state": true },
      "specs": {}
    },
    "adcs": {
      "defaults": { "roll": 0, "pitch": 0, "yaw": 0, "stabilization": true, "mode": "sun-track" },
      "specs": { "mass": 3, "momentOfInertia": 0.015, "motorSpeed": 2 }
    },
    "obc": {
      "defaults": { "uptime": 0, "temp": 22, "rebooting": false },
      "specs": { "rebootTime": 20, "maxTemp": 85 }
    },
    "auth": {
      "defaults": { "key": "DEFAULT" },
      "specs": {}
    }
  }
}
