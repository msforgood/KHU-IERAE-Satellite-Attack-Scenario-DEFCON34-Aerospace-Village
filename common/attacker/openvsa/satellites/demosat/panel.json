{
  "sections": [
    {
      "title": "POWER / ENERGY SUPPLY",
      "fields": [
        { "label": "Solar Panel", "source": "solar_panel.angle", "unit": "°", "indicator": { "source": "_flags.solarAttacked", "nominal": "SUN-TRACKING", "danger": "SUN-TRACK LOST" } },
        { "label": "Power Gen", "source": "solar_panel.power", "unit": " W", "decimals": 2, "dangerBelow": 2, "warnBelow": 3.5 },
        { "label": "Battery", "source": "battery.level", "unit": "%", "bar": true, "dangerBelow": 30, "warnBelow": 60 }
      ]
    },
    {
      "title": "ADCS",
      "fields": [
        { "label": "Reaction Wheel Torque", "source": "adcs.torque", "unit": " mNm", "dangerAbove": 500, "warnAbove": 300 },
        { "label": "Attitude", "sources": ["adcs.roll", "adcs.pitch", "adcs.yaw"], "format": "{0}° / {1}° / {2}°", "decimals": 1, "indicator": { "source": "_flags.tumbling", "nominal": "STABLE", "danger": "TUMBLING" } },
        { "label": "Stabilization", "source": "adcs.stabilization", "boolean": { "true": "ENABLED", "false": "DISABLED" }, "dangerWhenFalse": true }
      ]
    },
    {
      "title": "COMM",
      "fields": [
        { "label": "Antenna", "sources": ["antenna.az", "antenna.el"], "format": "{0}° / {1}°", "indicator": { "source": "_flags.antennaAttacked", "nominal": "NOMINAL", "danger": "HIJACKED" } },
        { "label": "Comm Link", "source": "comm.status", "commStatus": true },
        { "label": "Transponder", "source": "transponder.state", "boolean": { "true": "ON", "false": "OFF" }, "dangerWhenFalse": true }
      ]
    },
    {
      "title": "OBC",
      "fields": [
        { "label": "Temp", "source": "obc.temp", "unit": "°C", "decimals": 1, "dangerAbove": 40, "warnAbove": 30 },
        { "label": "Uptime", "source": "obc.uptime", "format": "uptime" },
        { "label": "TT&C Auth", "source": "auth.key", "alwaysShow": true, "dangerValues": ["ATTACKER", "CORRUPTED"] }
      ]
    }
  ]
}
